{
  "name": "CommonMark 0.31.2 seed fixtures",
  "profile": "commonmark",
  "commonmarkCompatible": true,
  "fixtures": [
    {
      "name": "paragraph emphasis and strong",
      "markdown": "Paragraph with **strong** and *emphasis*.\n",
      "expected": "<p>Paragraph with <strong>strong</strong> and <em>emphasis</em>.</p>"
    },
    {
      "name": "delimiter stack nested strong inside emphasis",
      "markdown": "*foo __bar *baz bim__ bam*\n",
      "expected": "<p><em>foo <strong>bar *baz bim</strong> bam</em></p>"
    },
    {
      "name": "unmatched longer code span run remains literal",
      "markdown": "```foo``\n",
      "expected": "<p>```foo``</p>"
    },
    {
      "name": "nested links deactivate outer opener",
      "markdown": "[foo [bar](/uri)](/uri)\n",
      "expected": "<p>[foo <a href=\"/uri\">bar</a>](/uri)</p>"
    },
    {
      "name": "image label preserves deactivated nested links in alt text",
      "markdown": "![[[foo](uri1)](uri2)](uri3)\n",
      "expected": "<p><img src=\"uri3\" alt=\"[foo](uri2)\" /></p>"
    },
    {
      "name": "escaped reference labels match only equivalent raw labels",
      "markdown": "[bar][foo\\!]\n\n[foo!]: /url\n",
      "expected": "<p>[bar][foo!]</p>"
    },
    {
      "name": "escaped reference labels match when both sides are escaped",
      "markdown": "[foo][ref\\[]\n\n[ref\\[]: /uri\n",
      "expected": "<p><a href=\"/uri\">foo</a></p>"
    },
    {
      "name": "named html5 character references",
      "markdown": "&frac12; &euro; &rarr;\n",
      "expected": "<p>\u00bd \u20ac \u2192</p>"
    },
    {
      "name": "blockquote lazy continuation",
      "markdown": "> quoted\n> text\n",
      "expected": "<blockquote>\n<p>quoted\ntext</p>\n</blockquote>"
    },
    {
      "name": "tight ordered list",
      "markdown": "1. one\n2. two\n",
      "expected": "<ol>\n<li>one</li>\n<li>two</li>\n</ol>"
    },
    {
      "name": "fenced code block",
      "markdown": "```\nconst value = 1;\n```\n",
      "expected": "<pre><code>const value = 1;\n</code></pre>"
    },
    {
      "name": "raw html block",
      "markdown": "<section>\n<p>Raw HTML.</p>\n</section>\n",
      "expected": "<section>\n<p>Raw HTML.</p>\n</section>"
    },
    {
      "name": "tab indentation and loose list item",
      "markdown": "- foo\n\n\t\tbar\n",
      "expected": "<ul>\n<li>\n<p>foo</p>\n<pre><code>  bar\n</code></pre>\n</li>\n</ul>"
    },
    {
      "name": "multiline link reference definition",
      "markdown": "[foo]:\n/url\n\"title\"\n\n[foo]\n",
      "expected": "<p><a href=\"/url\" title=\"title\">foo</a></p>"
    },
    {
      "name": "inline raw html and hard break",
      "markdown": "<a/><b2/>\nfoo  \nbar\n",
      "expected": "<p><a/><b2/>\nfoo<br />\nbar</p>"
    }
  ]
}
