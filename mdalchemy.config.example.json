{
  "version": 1,
  "output": {
    "format": "html",
    "standalone": true,
    "createDirs": false
  },
  "markdown": {
    "profile": "commonmark",
    "extensions": [
      "gfm-table",
      "gfm-task-list",
      "gfm-strikethrough",
      "gfm-footnote",
      "gfm-literal-autolink",
      "gfm-tagfilter",
      "frontmatter"
    ]
  },
  "html": {
    "lang": "en",
    "rawHtml": "allow",
    "safeUrls": true,
    "headingAnchors": true,
    "sections": false,
    "collapsibleSections": false,
    "tableOfContents": "auto",
    "tocDepth": 3,
    "softBreak": "newline"
  },
  "theme": "./examples/themes/warm-report.json"
}
